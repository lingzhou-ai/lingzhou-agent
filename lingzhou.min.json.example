{
  "_doc": "最小启动配置——只需这两个字段，其余全走 Pydantic 内建默认值。随着运行，agent 会通过 config.set 工具按需写入更多字段，配置文件会自然地长出来。完整参考见 lingzhou.json.example。",

  "providers": {
    "bailian": {
      "type": "openai_compat",
      "base_url": "https://dashscope.aliyuncs.com/compatible-mode/v1",
      "api_key_env": "DASHSCOPE_API_KEY"
    }
  },

  "model": "bailian/qwen3.6-plus"
}
